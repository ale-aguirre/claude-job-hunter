# ── Job Hunter — Configuration ────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ── Your Profile ──────────────────────────────────────────────────────────────
FIRST_NAME=Jane
LAST_NAME=Doe
EMAIL=jane@example.com
PHONE=+1 555 000 0000
LINKEDIN=https://linkedin.com/in/your-profile
GITHUB=https://github.com/your-username
PORTFOLIO=https://yoursite.com
CITY=Your City, Country

# Path to your CV/resume PDF (used for file upload on ATS forms)
CV_PATH=/path/to/your/CV.pdf

# Short bio used in cover letters and LLM prompts (one line, ~50 words)
PROFILE_TEXT=Frontend developer with 4+ years shipping production apps. Stack: React, Next.js, TypeScript, Node.js. Available immediately for remote work.

# Optional: override the default cover letter template entirely
# BASE_COVER=Hi,\n\nI'm Jane Doe...

# ── API Keys ──────────────────────────────────────────────────────────────────
# Groq — FREE tier. Used for orchestration (Senku/Nanami), cover letters, research.
# Get yours: https://console.groq.com
GROQ_API_KEY=

# Anthropic — optional, preferred for Senku/Nanami orchestration (more reliable JSON)
# Falls back to Groq if not set. Get yours: https://console.anthropic.com
# ANTHROPIC_API_KEY=

# ── Chrome ────────────────────────────────────────────────────────────────────
# Path to Chrome binary (default: macOS standard location)
# CHROME_BIN=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Chrome profile with your active sessions (LinkedIn, X, Gmail, etc.)
# Default: ~/Library/Application Support/Google/Chrome/Profile 1
# On Linux: ~/.config/google-chrome/Default
# CHROME_PROFILE=/path/to/chrome/profile

# ── Search Targeting ──────────────────────────────────────────────────────────
# Comma-separated skills/tags for job search (used by scout-api and agent-xreddit)
SEARCH_TAGS=react,typescript,nextjs,frontend

# Your target location / timezone preference (shown in header + used in search prompts)
SEARCH_LOCATION=Remote, Americas

# Your salary/rate target (shown in header and income goal bar)
SALARY_TARGET=$2,500/mo

# Optional: pipe-separated custom X.com search queries (overrides SEARCH_TAGS)
# X_SEARCHES=hiring react developer remote|typescript fullstack hiring

# ── Twitter/X Auth (for agent-xreddit X.com search) ──────────────────────────
# How to get: Open x.com in Chrome → DevTools (F12) → Application → Cookies → x.com
# Copy the value of the cookie named "auth_token"
TWITTER_AUTH_TOKEN=
# Copy the value of the cookie named "ct0"
TWITTER_CT0=

# ── Siftly (optional — bookmarks agent) ───────────────────────────────────────
# Path to Siftly SQLite DB (if you use Siftly bookmarks)
# SIFTLY_DB_PATH=/path/to/Siftly/prisma/dev.db

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4242
